# Copy this file to .env and fill in your values
# Never commit .env to git

# ── Database ──────────────────────────────────────────────────────────────────
# Overridden by docker-compose for container networking; used directly for local dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/startupinfo

# ── Auth ──────────────────────────────────────────────────────────────────────
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changeme-replace-with-a-long-random-string

ACCESS_TOKEN_EXPIRE_DAYS=7

# ── App ───────────────────────────────────────────────────────────────────────
ENVIRONMENT=local
LOG_LEVEL=info
